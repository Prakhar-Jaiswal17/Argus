{
    "builds": [
        {
            "src": "api/server.py",
            "use": "@vercel/python"
        },
        {
            "src": "index.html",
            "use": "@vercel/static"
        },
        {
            "src": "style.css",
            "use": "@vercel/static"
        },
        {
            "src": "script.js",
            "use": "@vercel/static"
        },
        {
            "src": "data/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/api/(.*)",
            "dest": "api/server.py"
        },
        {
            "src": "/style.css",
            "dest": "style.css"
        },
        {
            "src": "/script.js",
            "dest": "script.js"
        },
        {
            "src": "/data/(.*)",
            "dest": "data/$1"
        },
        {
            "src": "/(.*)",
            "dest": "api/server.py"
        }
    ]
}